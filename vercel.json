{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'self' *" }
      ]
    }
  ],
  "functions": {
    "pages/api/proxy.js": {
      "maxDuration": 30
    }
  }
}
